{
    "name": "const-tech/whatsapp-gateway",
    "description": "Reusable WhatsApp Gateway client + self-service subscription flow for Laravel projects (c-wts.com / Ultramsg compatible).",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Const Tech",
            "email": "info@c-wts.com",
            "homepage": "http://c-wts.com/",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.3|^8.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0",
        "illuminate/http": "^8.0|^9.0|^10.0|^11.0",
        "illuminate/database": "^8.0|^9.0|^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "ConstTech\\WhatsappGateway\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ConstTech\\WhatsappGateway\\WhatsappGatewayServiceProvider"
            ],
            "aliases": {
                "WhatsappGateway": "ConstTech\\WhatsappGateway\\Facades\\WhatsappGateway"
            }
        }
    },
    "replace": {
        "almarwa/whatsapp-gateway": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}